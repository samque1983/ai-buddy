# ---- Supabase (create a project at https://supabase.com, or `supabase start` locally) ----
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Server-only. Used by post-session background processing. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ---- AI providers ----
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# ---- Provider selection (swappable without code changes) ----
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-5
STT_PROVIDER=openai
STT_MODEL=whisper-1
TTS_PROVIDER=openai
TTS_MODEL=tts-1

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
